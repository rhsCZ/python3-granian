#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

export DH_VERBOSE=1

DIST_DIR := $(CURDIR)/dist
TOOLBIN_DIR := $(CURDIR)/debian/toolbin
CARGO_BIN := /usr/bin/cargo-1.91
RUSTC_BIN := /usr/bin/rustc-1.91
MATURIN_BIN := /usr/bin/maturin

export CARGO_HOME := $(CURDIR)/debian/.cargo-home
export CARGO_NET_OFFLINE := true
export PIP_DISABLE_PIP_VERSION_CHECK := 1
export PIP_NO_PYTHON_VERSION_WARNING := 1
export PATH := $(TOOLBIN_DIR):$(PATH)

ifeq ($(DEB_HOST_ARCH),armhf)
export CARGO_BUILD_JOBS := 1
export CARGO_PROFILE_RELEASE_LTO := thin
endif

%:
	dh $@ --with python3

override_dh_auto_build:
	test -x $(CARGO_BIN)
	test -x $(RUSTC_BIN)
	test -x $(MATURIN_BIN)
	echo "Memory snapshot before Rust build:"
	free -h
	mkdir -p $(TOOLBIN_DIR)
	ln -sf $(CARGO_BIN) $(TOOLBIN_DIR)/cargo
	ln -sf $(RUSTC_BIN) $(TOOLBIN_DIR)/rustc
	$(MATURIN_BIN) build --release --locked --offline --manifest-path Cargo.toml --interpreter python3 --out $(DIST_DIR)

override_dh_auto_install:
	python3 -m pip install --no-deps --no-index --find-links=$(DIST_DIR) --root=debian/python3-granian --prefix=/usr granian
	mkdir -p debian/python3-granian/usr/bin debian/python3-granian/usr/lib/python3/dist-packages
	mv debian/python3-granian/usr/local/bin/granian debian/python3-granian/usr/bin/
	sh -ec 'mv debian/python3-granian/usr/local/lib/python3*/dist-packages/* debian/python3-granian/usr/lib/python3/dist-packages/'
	rm -rf debian/python3-granian/usr/local

override_dh_auto_clean:
	dh_auto_clean
	rm -rf $(DIST_DIR) $(CARGO_HOME) $(TOOLBIN_DIR) $(CURDIR)/target
